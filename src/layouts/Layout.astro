---
import MetaHead from "../components/MetaHead.astro";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scrollbar-thin scrollbar-gutter-stable">
  <head>
    <MetaHead />
    <title>{(title ? `${title} | ` : "") + "orangishcat's happy place"}</title>
  </head>
  <body>
    <main
      class="mx-auto px-16 pt-20 pb-44 min-h-screen place-items-center ml-1 relative"
    >
      <slot />
      <div
        class="absolute text-center bottom-0 w-full pt-12 pb-6 text-gray-400 bg-linear-to-b from-transparent to-black/80"
      >
        Made with <span class="text-red-400">&lt;3</span> by
        <span class="text-primary">orangishcat</span>. © 2026 orangishcat. All
        rights reserved.
      </div>
    </main>
  </body>
</html>
