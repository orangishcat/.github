---
import Layout from "../layouts/Layout.astro";
import A from "../components/Anchor.astro";
import Banner from "../components/Banner.astro";
import Links from "../components/Links.astro";
import { projects, blogs } from "../data.ts";
---

<Layout>
  <div class="w-full h-full max-w-6xl">
    <Banner />
    <div
      class="grid grid-cols-[1fr_3fr_1fr] content-stretch justify-items-stretch gap-4 rounded-2xl mb-12"
    >
      <!-- First column -->
      <div class="flex flex-col [&>div]:py-2 text-center relative">
        <img draggable="false" src="/assets/plant.avif" class="-mb-1.5 z-10" />
        <div
          class="flex flex-col border border-gray-600 bg-background [&>a>div]:flex [&>a>div]:gap-2 [&>a>div]:justify-center"
        >
          <h2 class="border-b border-gray-600">Socials</h2>
          <A href="https://github.com/orangishcat">
            <div>GitHub</div>
          </A>
          <span class="text-xs text-gray-400 px-2">
            I do have other social media accounts, I just never use them.
          </span>
        </div>
        <div class="my-8"></div>
        <img
          draggable="false"
          src="/assets/clock.apng"
          class="w-1/2 mx-auto -mb-0.5 z-10"
        />
        <div class="border border-gray-600 p-0!">
          <h2 class="mt-2">Projects</h2>
          <div class="text-left [&>a>div]:border-t [&>a>div]:border-gray-600">
            {
              projects.map((obj) => (
                <A
                  href={obj.url}
                  class="hover:no-underline! hover:brightness-100!"
                >
                  <div class="hover:bg-background-light text-xs px-2 pt-1 pb-2 group transition-colors duration-400">
                    <h3 class="text-[1.35rem]!">{obj.title} </h3>
                    {obj.note && (
                      <div class="mb-1 text-sm text-gray-300">({obj.note})</div>
                    )}
                    <div class="text-[0.75rem] line-clamp-2 group-hover:line-clamp-none max-h-12 group-hover:max-h-60 transition-colors duration-400 ease-in-out text-gray-400 group-hover:text-white">
                      {obj.description}
                    </div>
                  </div>
                </A>
              ))
            }
          </div>
        </div>
        <br />
        <A
          href="/blog/personal-website"
          class="absolute bottom-8 hover:scale-130 transition"
        >
          <img draggable="false" src="/assets/book.apng" />
        </A>
        <br />
      </div>

      <!-- Second column -->
      <div class="border-gray-600 border space-y-6 p-4">
        <div>
          <h2>About me</h2>
          <p>
            <span class="text-lg">Hi hi!</span><br />
            I'm a <ac>high school programmer</ac> who occasionally codes random stuff!
            <br />
          </p>
          <p>
            I post my projects, blog posts, and devlogs on this website. This
            site is just my little corner of the internet :D
          </p>
          <p>
            I'm definitely not a great artist, but I try out art sometimes just
            for fun!
          </p>
          <p>
            Some facts about me:
            <ul>
              <li>I live in <ac>California, USA</ac>!</li>
              <li>I like cats! (obviously)</li>
              <li>I like the outdoors too!</li>
              <li>I'm a night owl. My sleep schedule is utterly terrible.</li>
              <li>
                I don't really have a favorite color, but if you asked me I
                would probably say <span class="text-primary">orange</span>.
              </li>
              <li>
                <A href="/about-me" class="text-accent">More about me</A>
              </li>
            </ul>
          </p>
        </div>
        <div>
          <h2>Programming skillset</h2>
          <p>
            I specialize mostly in <ac>webdev</ac> and <ac>Minecraft modding</ac
            >, and I know a lot about <ac>Python</ac> and have used it for robotics
            and data science.
          </p>
          <p>
            I have worked with <ac>C++</ac> for robotics before, but I want to improve
            and also try out <ac>Rust</ac>. I usually don't focus much on
            low-level development though, as manual memory management is a pain.
          </p>
        </div>
        <div>
          <h2>Hobbies</h2>
          <ul>
            <li><ac>Programming</ac>!</li>
            <li>
              <ac>Running</ac>. It's good exercise that I can do fully by
              myself, and I can explore the outdoors!
            </li>
            <li>
              <ac>Hiking</ac>. I like nature and the outdoors, and exploring it.
            </li>
            <li>
              <ac>Piano</ac>. I used to take classes but then got bored. I now
              practice occasionally by myself.
            </li>
            <li>
              <ac>Video games</ac>!
            </li>
          </ul>
        </div>
        <div>
          <h2>Want to learn</h2>
          <p>
            Haven't done much hardware outside of robotics, and I try out art
            for fun sometimes, like for making this website! I hope to improve
            at both someday :)
          </p>
          <p>
            And I might want to try composing music? I'm not very good at it
            though...
          </p>
        </div>
        <div>
          <h2>Games I like</h2>
          <div class="grid grid-cols-4 gap-3">
            <A href="https://www.minecraft.net/en-us">
              <img draggable="false" src="/assets/minecraft.avif" />
            </A>
            <A href="https://osu.ppy.sh/">
              <img draggable="false" src="/assets/osu.avif" />
            </A>
            <A href="https://deltarune.com/">
              <img draggable="false" src="/assets/deltarune.avif" />
            </A>
            <A
              href="https://store.steampowered.com/app/1660910/Tanks_The_Crusades/"
            >
              <img draggable="false" src="/assets/ttc.avif" />
            </A>
          </div>
        </div>
        <div>
          <p>
            Thank you for making it to the end! Hope you have a nice day <span
              class="text-red-400">&lt;3</span
            >
          </p>
        </div>
      </div>

      <!-- Third column -->
      <div class="text-center relative">
        <Links />
        <div class="py-8"></div>
        <div class="border-gray-600 border pt-2">
          <h2>Blog</h2>
          <div class="[&>a>div]:border-t [&>a>div]:border-gray-600 text-left">
            {
              blogs.map((obj) => (
                <A
                  href={`/blog/${obj.slug}`}
                  class="hover:no-underline! hover:brightness-100!"
                >
                  <div class="p-2 group hover:bg-background-light transition-colors duration-400">
                    <h3 class="text-[1.15rem]! line-clamp-2 group-hover:line-clamp-none w-full leading-5">
                      {obj.title}
                    </h3>
                    <div class="mb-1 text-sm text-gray-300">({obj.date})</div>
                    <div class="text-[0.75rem] line-clamp-2 group-hover:line-clamp-none max-h-12 group-hover:max-h-60 transition-colors duration-400 ease-in-out text-gray-400 group-hover:text-white">
                      {obj.description}
                    </div>
                  </div>
                </A>
              ))
            }
          </div>
        </div>
        <br />
        <br />
        <div class="absolute bottom-12 right-0 w-full">
          <div class="w-full relative">
            <img draggable="false" src="/assets/computer.avif" class="w-full" />
            <video
              autoplay
              muted
              src="/assets/gameplay.webm"
              class="absolute top-12.5 left-14 w-32"></video>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
