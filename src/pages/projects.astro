---
import Layout from "../layouts/Layout.astro";
import Banner from "../components/Banner.astro";
import Links from "../components/Links.astro";
import A from "../components/Anchor.astro";
import { projects } from "../data.js";
---

<Layout>
  <div class="w-full h-full max-w-4xl">
    <Banner />
    <div
      class="grid grid-cols-[3.5fr_1fr] content-stretch justify-items-stretch gap-4 rounded-2xl mb-12"
    >
      <!-- First column -->
      <div class="border border-gray-600">
        <h1 class="text-center text-5xl! my-4!">Projects</h1>
        <div
          class="[&>a>div]:border-t [&>a>div]:border-gray-700 [&>a>div]:border-b"
        >
          {
            projects.map((obj) => (
              <A
                href={obj.url}
                class="hover:no-underline! hover:brightness-100!"
              >
                <div class="hover:bg-background-light px-6 pt-3 pb-4">
                  <h3 class="text-[1.75rem]!">
                    {obj.title}{" "}
                    {obj.note && (
                      <span class="text-gray-400 ml-1 text-2xl">
                        ({obj.note})
                      </span>
                    )}
                  </h3>
                  <span>{obj.description}</span>
                </div>
              </A>
            ))
          }
        </div>
      </div>
      <div>
        <!-- Second column -->
        <Links />
      </div>
    </div>
  </div>
</Layout>
